{
  "schemaVersion": 1,
  "id": "single_arm_chest_supported_incline_row",
  "name": "Single-Arm Chest-Supported Incline Row",
  "coordinate_space": "image2d",
  "setup": {
    "required_view": "side",
    "required_landmarks": [
      "left.shoulder",
      "left.elbow",
      "left.wrist",
      "left.hip"
    ],
    "min_visibility": 0.65,
    "primary_side": "left",
    "mirror_handling": "detect",
    "calibration": {
      "top_pose": {
        "instruction": "Set up side-on with your chest supported on the incline bench and left arm hanging long",
        "capture_seconds": 1.0,
        "signals": [
          "row_elbow",
          "row_shoulder",
          "torso_tilt"
        ]
      }
    }
  },
  "landmark_aliases": {
    "shoulder": "left.shoulder",
    "elbow": "left.elbow",
    "wrist": "left.wrist",
    "hip": "left.hip"
  },
  "signals": {
    "row_elbow_raw": "angle(left.shoulder, left.elbow, left.wrist)",
    "row_shoulder_raw": "angle(left.elbow, left.shoulder, left.hip)",
    "torso_raw": "angle_to_vertical(left.shoulder, left.hip)"
  },
  "filters": {
    "row_elbow": {
      "source": "row_elbow_raw",
      "type": "ema",
      "alpha": 0.45
    },
    "row_shoulder": {
      "source": "row_shoulder_raw",
      "type": "median",
      "window_ms": 200
    },
    "torso_tilt": {
      "source": "torso_raw",
      "type": "median",
      "window_ms": 200
    }
  },
  "validity": {
    "min_signal_confidence": 0.65,
    "phase_signal_invalid_policy": "freeze_then_reset",
    "freeze_ms": 500,
    "reset_after_ms": 1500
  },
  "rep": {
    "phase_signal": "row_elbow",
    "down_when": "row_elbow < 95",
    "down_min_ms": 100,
    "bottom_min_ms": 80,
    "up_when": "row_elbow > 150",
    "up_min_ms": 100,
    "min_rom_deg": 55,
    "cooldown_ms": 250
  },
  "hold": null,
  "form_rules": [
    {
      "id": "row_finish",
      "when": "phase == 'bottom'",
      "expect": "row_elbow <= 90",
      "min_violation_ms": 250,
      "cue": "Row the dumbbell closer to your ribs",
      "severity": "warn",
      "score_weight": 10,
      "cooldown_ms": 1500,
      "evaluation": "extreme"
    },
    {
      "id": "elbow_path",
      "when": "phase == 'bottom'",
      "expect": "row_shoulder >= 45",
      "min_violation_ms": 250,
      "cue": "Pull your left elbow back along your side",
      "severity": "warn",
      "score_weight": 8,
      "cooldown_ms": 1500,
      "evaluation": "extreme"
    },
    {
      "id": "torso",
      "when": "phase in ['descending','bottom']",
      "expect": "torso_tilt <= 50",
      "min_violation_ms": 250,
      "cue": "Keep your chest set on the bench",
      "severity": "info",
      "score_weight": 4,
      "cooldown_ms": 2000
    }
  ],
  "set": {
    "target_reps": 10
  }
}
