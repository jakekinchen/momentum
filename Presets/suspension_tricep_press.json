{
  "schemaVersion": 1,
  "id": "suspension_tricep_press",
  "name": "Suspension Tricep Press",
  "coordinate_space": "image2d",
  "setup": {
    "required_view": "side",
    "required_landmarks": [
      "primary.shoulder",
      "primary.elbow",
      "primary.wrist",
      "primary.hip",
      "primary.knee",
      "primary.ankle"
    ],
    "min_visibility": 0.65,
    "primary_side": "auto_lock",
    "mirror_handling": "detect",
    "calibration": {
      "top_pose": {
        "instruction": "Lean into the straps side-on with elbows bent and body in one long line",
        "capture_seconds": 1.0,
        "signals": [
          "elbow_angle",
          "body_line",
          "upper_arm_body"
        ]
      }
    }
  },
  "landmark_aliases": {
    "shoulder": "primary.shoulder",
    "elbow": "primary.elbow",
    "wrist": "primary.wrist",
    "hip": "primary.hip",
    "knee": "primary.knee",
    "ankle": "primary.ankle"
  },
  "signals": {
    "elbow_angle_raw": "angle(primary.shoulder, primary.elbow, primary.wrist)",
    "body_line_raw": "angle(primary.shoulder, primary.hip, primary.ankle)",
    "upper_arm_body_raw": "angle(primary.hip, primary.shoulder, primary.elbow)"
  },
  "filters": {
    "elbow_angle": {
      "source": "elbow_angle_raw",
      "type": "ema",
      "alpha": 0.45
    },
    "body_line": {
      "source": "body_line_raw",
      "type": "median",
      "window_ms": 200
    },
    "upper_arm_body": {
      "source": "upper_arm_body_raw",
      "type": "median",
      "window_ms": 200
    }
  },
  "validity": {
    "min_signal_confidence": 0.65,
    "phase_signal_invalid_policy": "freeze_then_reset",
    "freeze_ms": 500,
    "reset_after_ms": 1500
  },
  "rep": {
    "phase_signal": "elbow_angle",
    "down_when": "elbow_angle > 150",
    "down_min_ms": 100,
    "bottom_min_ms": 80,
    "up_when": "elbow_angle < 95",
    "up_min_ms": 100,
    "min_rom_deg": 50,
    "cooldown_ms": 250
  },
  "hold": null,
  "form_rules": [
    {
      "id": "press_finish",
      "when": "phase == 'bottom'",
      "expect": "elbow_angle >= 160",
      "min_violation_ms": 250,
      "cue": "Press until your elbows are nearly straight",
      "severity": "warn",
      "score_weight": 10,
      "cooldown_ms": 1500,
      "evaluation": "extreme"
    },
    {
      "id": "body_line",
      "when": "phase in ['descending','bottom']",
      "expect": "body_line >= 150",
      "min_violation_ms": 250,
      "cue": "Keep your body in one long line",
      "severity": "warn",
      "score_weight": 8,
      "cooldown_ms": 1500
    },
    {
      "id": "upper_arm_path",
      "when": "phase in ['descending','bottom']",
      "expect": "upper_arm_body <= 30",
      "min_violation_ms": 250,
      "cue": "Keep your upper arms in line with your torso",
      "severity": "info",
      "score_weight": 4,
      "cooldown_ms": 2000
    }
  ],
  "set": {
    "target_reps": 10
  }
}
